# ==================================================================================
# BTS Neural Archive - Environment Configuration Example
# ==================================================================================
#
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# Vite exposes env variables to your app that start with VITE_
# They are replaced at build time with their actual values
#
# Learn more: https://vitejs.dev/guide/env-and-mode.html
# ==================================================================================

# ==================== APPLICATION CONFIGURATION ====================

# Application environment (development | production | staging)
# Controls logging, debugging, and optimization levels
VITE_APP_ENV=development

# Application base URL (used for routing and API calls)
# Local development typically uses localhost:5173
VITE_APP_BASE_URL=http://localhost:5173

# Application title (displayed in browser tab and meta tags)
VITE_APP_TITLE="BTS Neural Archive"

# Application description (for meta tags and SEO)
VITE_APP_DESCRIPTION="Immersive cosmic-themed archive and analytical hub for BTS's musical universe"


# ==================== API & BACKEND CONFIGURATION ====================

# Backend API base URL (when backend is implemented)
# Uncomment when you have a backend service
# VITE_API_BASE_URL=http://localhost:3000/api
# VITE_API_BASE_URL=https://api.bts-archive.com

# API request timeout in milliseconds
# VITE_API_TIMEOUT=30000

# API rate limiting (requests per minute)
# VITE_API_RATE_LIMIT=60

# API authentication token (if using protected endpoints)
# VITE_API_AUTH_TOKEN=your_secret_token_here


# ==================== MUSIC & AUDIO SERVICES ====================

# Spotify API credentials (for music data and analysis)
# Get your credentials at: https://developer.spotify.com/dashboard
# VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
# VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Last.fm API key (for music metadata and scrobbling)
# Get your API key at: https://www.last.fm/api/account/create
# VITE_LASTFM_API_KEY=your_lastfm_api_key

# YouTube Data API key (for music video integration)
# Get your API key at: https://console.cloud.google.com/
# VITE_YOUTUBE_API_KEY=your_youtube_api_key


# ==================== RAG (RETRIEVAL-AUGMENTED GENERATION) ====================

# OpenAI API key (for RAG search and semantic analysis)
# Get your API key at: https://platform.openai.com/api-keys
# VITE_OPENAI_API_KEY=your_openai_api_key

# Vector database configuration (for semantic search)
# VITE_VECTOR_DB_URL=http://localhost:6333
# VITE_VECTOR_DB_COLLECTION=bts_lyrics

# Embedding model to use (text-embedding-3-small | text-embedding-3-large)
# VITE_EMBEDDING_MODEL=text-embedding-3-small


# ==================== ANALYTICS & MONITORING ====================

# Google Analytics tracking ID
# Get your tracking ID at: https://analytics.google.com/
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking and monitoring
# Get your DSN at: https://sentry.io/
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# PostHog analytics (for product analytics and feature flags)
# Get your key at: https://posthog.com/
# VITE_POSTHOG_KEY=your_posthog_key
# VITE_POSTHOG_HOST=https://app.posthog.com


# ==================== FEATURE FLAGS ====================

# Enable/disable features during development

# Enable audio waveform visualization (requires audio processing)
VITE_ENABLE_AUDIO_VISUALIZATION=true

# Enable RAG semantic search (requires OpenAI API key)
VITE_ENABLE_RAG_SEARCH=false

# Enable 3D cosmic universe background
VITE_ENABLE_3D_UNIVERSE=true

# Enable member DNA profiles
VITE_ENABLE_MEMBER_PROFILES=true

# Enable sonic analysis lab
VITE_ENABLE_SONIC_LAB=true

# Enable data export functionality
VITE_ENABLE_DATA_EXPORT=true

# Enable experimental features (unstable)
VITE_ENABLE_EXPERIMENTAL=false


# ==================== DEPLOYMENT & CDN ====================

# CDN URL for static assets (images, audio files)
# VITE_CDN_URL=https://cdn.bts-archive.com

# Asset base path (for custom deployment paths)
# VITE_BASE_PATH=/

# Public assets directory
# VITE_PUBLIC_PATH=/public


# ==================== SOCIAL & COMMUNITY ====================

# Discord webhook URL (for community notifications)
# VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Twitter/X API credentials (for social media integration)
# VITE_TWITTER_API_KEY=your_twitter_api_key
# VITE_TWITTER_API_SECRET=your_twitter_api_secret

# GitHub repository URL (for issue reporting and contributions)
VITE_GITHUB_REPO=https://github.com/itsmepraks/BTS-universe


# ==================== DEVELOPMENT & DEBUGGING ====================

# Enable debug mode (shows additional logging and dev tools)
VITE_DEBUG=false

# Enable performance profiling
VITE_ENABLE_PROFILING=false

# Show FPS counter in 3D universe
VITE_SHOW_FPS=false

# Mock API responses (for development without backend)
VITE_MOCK_API=false

# Development port (default: 5173)
# VITE_PORT=5173


# ==================== LOCALIZATION ====================

# Default language (en | ko | ja | zh)
VITE_DEFAULT_LANGUAGE=en

# Enable Korean language support (한국어)
VITE_ENABLE_KOREAN=true

# Enable Japanese language support (日本語)
VITE_ENABLE_JAPANESE=false

# Enable Chinese language support (中文)
VITE_ENABLE_CHINESE=false


# ==================== ADVANCED CONFIGURATION ====================

# Maximum number of stars in 3D universe (affects performance)
VITE_MAX_STARS=800

# Bokeh bubble count (affects performance)
VITE_BOKEH_COUNT=30

# Animation quality (low | medium | high)
VITE_ANIMATION_QUALITY=high

# Enable service worker (for offline support)
VITE_ENABLE_SERVICE_WORKER=false


# ==================== SECURITY ====================

# Content Security Policy (CSP) nonce (for inline scripts)
# VITE_CSP_NONCE=random_nonce_here

# Allowed CORS origins (comma-separated)
# VITE_CORS_ORIGINS=http://localhost:5173,https://bts-archive.com


# ==================================================================================
# END OF CONFIGURATION
# ==================================================================================
#
# 💜 Note: Never commit .env.local to version control!
# Add it to .gitignore to keep your secrets safe.
#
# Made with 💜 for BTS & ARMY
# "어떤 빛이 맞는 빛일까 (Which light would be the right one?)" - Mikrokosmos
