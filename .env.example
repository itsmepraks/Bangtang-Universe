# ============================================================================
# Bangtan Universe - Environment Configuration
# ============================================================================
# Copy this file to `.env` for local development
# DO NOT commit `.env` - it's already in .gitignore
# ============================================================================

# ==================== DATABASE (SUPABASE) ====================

# Supabase Project URL
# Get from: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://bgabwguiuqbhknadgqfm.supabase.co

# Supabase Anonymous (Public) Key - used by frontend (read-only)
# Get from: Supabase Dashboard → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJnYWJ3Z3VpdXFiaGtuYWRncWZtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njk4MTUwMDEsImV4cCI6MjA4NTM5MTAwMX0.4bqJ31amMT3AD-OXCMUGnU0R9VpcK7jK2I_x11V9pls

# Supabase Service Role Key - used by migration script (write access)
# Get from: Supabase Dashboard → Settings → API → service_role
# ⚠️ KEEP THIS SECRET - only used for migration scripts, never in frontend!
SUPABASE_SERVICE_ROLE_KEY=

# ==================== MUSIC APIs ====================

# Spotify API (for audio features scraping)
# Get credentials at: https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_CLIENT_SECRET=

# Genius API (for lyrics scraping)
# Get access token at: https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=

# ==================== APPLICATION ====================

# Environment mode
VITE_APP_ENV=development

# Application base URL
VITE_APP_BASE_URL=http://localhost:5173

# ==================== FEATURE FLAGS ====================

# Enable 3D universe background
VITE_ENABLE_3D_UNIVERSE=true

# Enable audio visualization
VITE_ENABLE_AUDIO_VISUALIZATION=true

# Enable AI-powered search (semantic/RAG)
VITE_ENABLE_AI_SEARCH=true

# AI search API URL (required when AI search is enabled)
# Example: https://your-api.com/search or /api/search (with proxy)
VITE_AI_SEARCH_API_URL=

# Enable data export
VITE_ENABLE_DATA_EXPORT=true

# ==================== PERFORMANCE ====================

# Maximum stars in universe animation
VITE_MAX_STARS=800

# Animation quality (low/medium/high)
VITE_ANIMATION_QUALITY=high

