# ============================================================================
# BTS Neural Archive - Environment Configuration Template
# ============================================================================
# 
# Copy this file to `.env.local` for local development
# DO NOT commit `.env.local` - it's already in .gitignore
# 
# For production deployments (Vercel/Netlify), set these in the platform's
# environment variables dashboard
# ============================================================================

# ==================== APPLICATION ====================

# Application environment mode
# Options: 'development' | 'production' | 'test'
VITE_APP_ENV=development

# Application base URL
# Local: http://localhost:5173
# Production: https://your-domain.com
VITE_APP_BASE_URL=http://localhost:5173

# Application name (for analytics and metadata)
VITE_APP_NAME="BTS Neural Archive"

# ==================== API CONFIGURATION ====================

# Backend API base URL (if/when you add a backend)
# Examples:
#   - Local: http://localhost:3000/api
#   - Production: https://api.your-domain.com
#   - Serverless: https://your-project.vercel.app/api
# VITE_API_BASE_URL=

# API request timeout (milliseconds)
# VITE_API_TIMEOUT=30000

# API key for external services (if needed)
# VITE_API_KEY=

# ==================== MUSIC & AUDIO ====================

# Spotify API (for music metadata & previews)
# Get credentials at: https://developer.spotify.com/dashboard
# VITE_SPOTIFY_CLIENT_ID=
# VITE_SPOTIFY_CLIENT_SECRET=

# Audio CDN URL (if using external audio hosting)
# VITE_AUDIO_CDN_URL=

# Enable audio waveform visualization
# VITE_ENABLE_AUDIO_VISUALIZATION=true

# ==================== AI & RAG FEATURES ====================

# OpenAI API Key (for RAG semantic search enhancement)
# Get key at: https://platform.openai.com/api-keys
# VITE_OPENAI_API_KEY=

# Vector Database URL (Pinecone, Weaviate, etc.)
# VITE_VECTOR_DB_URL=
# VITE_VECTOR_DB_API_KEY=

# Enable RAG-powered search
# VITE_ENABLE_RAG_SEARCH=true

# ==================== ANALYTICS & TRACKING ====================

# Google Analytics Tracking ID (GA4)
# Format: G-XXXXXXXXXX
# VITE_GA_MEASUREMENT_ID=

# Vercel Analytics
# VITE_VERCEL_ANALYTICS_ID=

# Plausible Analytics (privacy-friendly alternative)
# VITE_PLAUSIBLE_DOMAIN=

# Enable analytics in development
# VITE_ENABLE_DEV_ANALYTICS=false

# ==================== SOCIAL & COMMUNITY ====================

# Discord webhook URL (for community notifications)
# VITE_DISCORD_WEBHOOK_URL=

# Twitter API credentials (for #BTS trending data)
# VITE_TWITTER_API_KEY=
# VITE_TWITTER_API_SECRET=

# GitHub API token (for contribution tracking)
# VITE_GITHUB_TOKEN=

# ==================== CONTENT & DATA ====================

# Content Management System (CMS) API
# Examples: Contentful, Sanity, Strapi
# VITE_CMS_API_URL=
# VITE_CMS_API_KEY=

# JSON data source URL (for remote song data)
# VITE_DATA_SOURCE_URL=

# Enable offline mode (use local data cache)
# VITE_OFFLINE_MODE=false

# ==================== FEATURE FLAGS ====================

# Enable experimental features
VITE_ENABLE_EXPERIMENTAL=false

# Enable 3D universe background
VITE_ENABLE_3D_UNIVERSE=true

# Enable Whalien 52 constellation animation
VITE_ENABLE_WHALE_ANIMATION=true

# Enable purple ocean bokeh effect
VITE_ENABLE_BOKEH_EFFECT=true

# Enable member DNA profiles
VITE_ENABLE_MEMBER_PROFILES=true

# Enable sonic analysis lab
VITE_ENABLE_SONIC_LAB=true

# Enable data export functionality
VITE_ENABLE_DATA_EXPORT=true

# ==================== PERFORMANCE & OPTIMIZATION ====================

# Maximum number of stars in the universe (800 default)
VITE_MAX_STARS=800

# Enable React Compiler optimizations
VITE_ENABLE_REACT_COMPILER=true

# Enable lazy loading for heavy components
VITE_ENABLE_LAZY_LOADING=true

# Animation quality (low/medium/high)
# Lower settings improve performance on slower devices
VITE_ANIMATION_QUALITY=high

# ==================== DEVELOPMENT & DEBUGGING ====================

# Enable debug mode (verbose console logs)
VITE_DEBUG=false

# Enable React DevTools
VITE_ENABLE_DEVTOOLS=true

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# Mock API responses (for offline development)
VITE_MOCK_API=false

# Show grid overlay (for design alignment)
VITE_SHOW_GRID=false

# ==================== LOCALIZATION ====================

# Default language (en, ko, ja, etc.)
VITE_DEFAULT_LOCALE=en

# Supported languages (comma-separated)
VITE_SUPPORTED_LOCALES=en,ko,ja

# ==================== SECURITY ====================

# CORS allowed origins (comma-separated)
# VITE_CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# Content Security Policy (CSP) mode
# Options: 'strict' | 'moderate' | 'relaxed'
# VITE_CSP_MODE=moderate

# Rate limiting (requests per minute)
# VITE_RATE_LIMIT=100

# ==================== THEMING ====================

# Default theme (borahae/light/dark/system)
VITE_DEFAULT_THEME=borahae

# Allow theme switching
VITE_ALLOW_THEME_SWITCH=true

# ==================== DEPLOYMENT ====================

# Deployment platform (vercel/netlify/cloudflare/custom)
# VITE_DEPLOYMENT_PLATFORM=vercel

# Build ID (auto-generated by CI/CD)
# VITE_BUILD_ID=

# Git commit SHA (for version tracking)
# VITE_GIT_SHA=

# Deployment timestamp
# VITE_DEPLOY_TIME=

# ==================== EASTER EGGS 🥚 ====================

# Enable secret ARMY easter eggs
VITE_ENABLE_EASTER_EGGS=true

# Konami code action (surprise/animation/message)
VITE_KONAMI_ACTION=surprise

# Special date messages (birthdays, comebacks)
VITE_ENABLE_SPECIAL_DATES=true

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
# 
# 💜 "You are my galaxy, my cosmos, my universe." 💜
