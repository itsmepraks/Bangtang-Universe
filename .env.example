# ==================== BTS NEURAL ARCHIVE - ENVIRONMENT CONFIGURATION ====================
# 
# This file serves as a template for environment variables used in the BTS Neural Archive.
# Copy this file to '.env.local' and update with your actual values.
#
# Note: Never commit .env.local or files containing actual secrets to version control!
#
# ========================================================================================

# ==================== APPLICATION SETTINGS ====================

# Application environment (development, staging, production)
VITE_APP_ENV=development

# Application base URL (used for routing and API calls)
VITE_APP_BASE_URL=http://localhost:5173

# Application name (displayed in browser tab and metadata)
VITE_APP_NAME="BTS Neural Archive"

# Application version (synced with package.json)
VITE_APP_VERSION=0.0.0

# ==================== API CONFIGURATION ====================
# Placeholder for future backend integration

# Backend API base URL
# VITE_API_BASE_URL=http://localhost:3000/api

# API request timeout (milliseconds)
# VITE_API_TIMEOUT=30000

# API key for authentication (if implementing backend)
# VITE_API_KEY=your_api_key_here

# ==================== EXTERNAL SERVICES ====================

# Spotify API (for future music integration)
# VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
# VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Last.fm API (for music data enrichment)
# VITE_LASTFM_API_KEY=your_lastfm_api_key

# YouTube Data API (for music video integration)
# VITE_YOUTUBE_API_KEY=your_youtube_api_key

# ==================== ANALYTICS & MONITORING ====================

# Google Analytics tracking ID
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Enable performance monitoring
# VITE_ENABLE_PERFORMANCE_MONITORING=false

# ==================== FEATURE FLAGS ====================

# Enable audio analysis features
VITE_ENABLE_AUDIO_ANALYSIS=true

# Enable RAG (Retrieval-Augmented Generation) search
VITE_ENABLE_RAG_SEARCH=true

# Enable member DNA profiles
VITE_ENABLE_MEMBER_PROFILES=true

# Enable data export functionality
VITE_ENABLE_DATA_EXPORT=true

# Enable 3D universe background
VITE_ENABLE_3D_UNIVERSE=true

# Enable experimental features
VITE_ENABLE_EXPERIMENTAL=false

# ==================== DEPLOYMENT SETTINGS ====================

# Deployment platform (vercel, netlify, github-pages, custom)
# VITE_DEPLOY_PLATFORM=vercel

# Production domain
# VITE_PRODUCTION_URL=https://bts-neural-archive.vercel.app

# CDN URL for static assets (optional)
# VITE_CDN_URL=https://cdn.example.com

# ==================== DEVELOPMENT SETTINGS ====================

# Enable debug mode (shows console logs and debugging info)
VITE_DEBUG=false

# Enable React DevTools
VITE_ENABLE_DEVTOOLS=true

# Hot module replacement port
# VITE_HMR_PORT=5173

# Source maps in production build
VITE_SOURCEMAPS=false

# ==================== CONTENT & DATA ====================

# Path to BTS discography data (local or remote)
# VITE_DATA_SOURCE=local

# Maximum number of songs to load
# VITE_MAX_SONGS=500

# Enable data caching
# VITE_ENABLE_CACHING=true

# Cache expiry time (milliseconds)
# VITE_CACHE_EXPIRY=3600000

# ==================== ACCESSIBILITY ====================

# Enable reduced motion mode
# VITE_REDUCED_MOTION=false

# Enable high contrast mode
# VITE_HIGH_CONTRAST=false

# Default language (en, ko, ja, etc.)
VITE_DEFAULT_LANGUAGE=en

# ==================== PERFORMANCE ====================

# Lazy load images
VITE_LAZY_LOAD_IMAGES=true

# Prefetch data on hover
# VITE_PREFETCH_ON_HOVER=true

# Maximum concurrent API requests
# VITE_MAX_CONCURRENT_REQUESTS=5

# ==================== SOCIAL & SHARING ====================

# Twitter/X handle for social sharing
# VITE_TWITTER_HANDLE=@BTSNeuralArchive

# Open Graph image URL
# VITE_OG_IMAGE_URL=https://your-domain.com/og-image.png

# ==================== NOTES ====================
# 
# 📝 Usage Instructions:
# 1. Copy this file: cp .env.example .env.local
# 2. Update values with your actual configuration
# 3. Restart the development server to apply changes
# 
# 🔐 Security:
# - Never commit .env.local to version control
# - Keep API keys and secrets confidential
# - Use different keys for development and production
# 
# 📚 More Info:
# - Vite Environment Variables: https://vitejs.dev/guide/env-and-mode.html
# - All variables must be prefixed with VITE_ to be exposed to client code
# 
# 💜 Made with Borahae for BTS & ARMY
