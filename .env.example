# ==================== BTS NEURAL ARCHIVE ====================
# Environment Configuration Template
# 
# Copy this file to .env.local for local development:
# cp .env.example .env.local
#
# Note: Vite exposes variables prefixed with VITE_ to the client.
# Never commit .env.local to version control!
# ============================================================

# ==================== APPLICATION SETTINGS ====================

# Application environment (development | production | staging)
VITE_APP_ENV=development

# Application name displayed in browser
VITE_APP_NAME="BTS Neural Archive"

# Application version (auto-populated from package.json or set manually)
VITE_APP_VERSION=0.0.0

# Base URL for the application
# Development: http://localhost:5173
# Production: https://your-domain.com
VITE_APP_BASE_URL=http://localhost:5173

# ==================== API & BACKEND (Future Use) ====================

# Backend API base URL (when RAG search backend is implemented)
# VITE_API_BASE_URL=http://localhost:3000/api
# VITE_API_TIMEOUT=30000

# Spotify API credentials (for song data enrichment)
# Get credentials at: https://developer.spotify.com/dashboard
# VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
# VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ==================== SEARCH & RAG SYSTEM ====================

# RAG (Retrieval-Augmented Generation) API endpoint
# VITE_RAG_API_URL=https://your-rag-service.com/api
# VITE_RAG_API_KEY=your_rag_api_key

# Vector database configuration (for semantic search)
# VITE_VECTOR_DB_URL=https://your-vector-db.com
# VITE_VECTOR_DB_API_KEY=your_vector_db_key

# ==================== AUDIO ANALYSIS ====================

# Audio analysis service (for waveform visualization)
# VITE_AUDIO_ANALYSIS_URL=https://your-audio-service.com
# VITE_AUDIO_ANALYSIS_KEY=your_audio_key

# Enable/disable real-time audio processing
VITE_ENABLE_AUDIO_PROCESSING=false

# Maximum audio file size in MB
VITE_MAX_AUDIO_SIZE_MB=50

# ==================== DATA SOURCES ====================

# KOMCA (Korea Music Copyright Association) API
# For fetching member songwriting/production credits
# VITE_KOMCA_API_URL=https://www.komca.or.kr/api
# VITE_KOMCA_API_KEY=your_komca_key

# BTS official discography data source
# VITE_DISCOGRAPHY_API_URL=https://your-discography-api.com
# VITE_DISCOGRAPHY_API_KEY=your_api_key

# ==================== ANALYTICS & MONITORING ====================

# Google Analytics tracking ID
# Get ID at: https://analytics.google.com
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry error tracking DSN
# Get DSN at: https://sentry.io
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# ==================== FEATURE FLAGS ====================

# Enable experimental 3D visualizations
VITE_ENABLE_3D_UNIVERSE=true

# Enable Sonic Analysis Lab
VITE_ENABLE_SONIC_LAB=true

# Enable RAG-powered semantic search
VITE_ENABLE_RAG_SEARCH=true

# Enable Member DNA Profiles
VITE_ENABLE_MEMBER_PROFILES=true

# Enable Data Hub export functionality
VITE_ENABLE_DATA_EXPORT=true

# Enable Whalien 52 constellation animation
VITE_ENABLE_WHALE_CONSTELLATION=true

# Enable shooting stars effect
VITE_ENABLE_SHOOTING_STARS=true

# ==================== UI/UX SETTINGS ====================

# Default theme (light | dark | cosmic)
VITE_DEFAULT_THEME=cosmic

# Enable animations (set to false for accessibility or performance)
VITE_ENABLE_ANIMATIONS=true

# Animation speed multiplier (0.5 = slower, 2.0 = faster)
VITE_ANIMATION_SPEED=1.0

# Enable glassmorphism effects
VITE_ENABLE_GLASSMORPHISM=true

# Enable particle effects (bokeh, floating particles)
VITE_ENABLE_PARTICLES=true

# Number of stars in the universe background
VITE_UNIVERSE_STAR_COUNT=800

# Number of bokeh bubbles in purple ocean
VITE_BOKEH_BUBBLE_COUNT=20

# ==================== PERFORMANCE ====================

# Enable React Compiler optimizations (experimental)
VITE_ENABLE_REACT_COMPILER=true

# Lazy load heavy components
VITE_ENABLE_LAZY_LOADING=true

# Prefetch strategy (hover | visible | none)
VITE_PREFETCH_STRATEGY=hover

# Maximum concurrent API requests
VITE_MAX_CONCURRENT_REQUESTS=6

# Cache timeout in milliseconds (default: 5 minutes)
VITE_CACHE_TIMEOUT=300000

# ==================== DEVELOPMENT ====================

# Enable debug mode (shows console logs, performance metrics)
VITE_DEBUG=false

# Enable hot module replacement
VITE_HMR=true

# Enable source maps in production
VITE_SOURCE_MAPS=false

# Mock API responses (for development without backend)
VITE_USE_MOCK_DATA=true

# ==================== SOCIAL & EXTERNAL LINKS ====================

# GitHub repository URL
VITE_GITHUB_URL=https://github.com/itsmepraks/BTS-universe

# Developer portfolio
VITE_PORTFOLIO_URL=https://praks.me

# Twitter/X handle for sharing
# VITE_TWITTER_HANDLE=@your_handle

# ==================== DEPLOYMENT ====================

# Deployment platform (vercel | netlify | github-pages | custom)
VITE_DEPLOY_PLATFORM=vercel

# Build output directory
VITE_BUILD_DIR=dist

# CDN URL for static assets (if using CDN)
# VITE_CDN_URL=https://cdn.your-domain.com

# ==================== SECURITY ====================

# Content Security Policy (CSP) mode (strict | moderate | off)
VITE_CSP_MODE=moderate

# Enable HTTPS redirect in production
VITE_FORCE_HTTPS=true

# Rate limiting (requests per minute)
VITE_RATE_LIMIT_RPM=60

# ==================== LOCALIZATION (Future) ====================

# Default language (en | ko | ja)
VITE_DEFAULT_LANGUAGE=en

# Enable language switcher
VITE_ENABLE_I18N=false

# ==================== NOTES ====================
# 
# Getting Started:
# 1. Copy this file: cp .env.example .env.local
# 2. Update values as needed for your environment
# 3. Never commit .env.local to version control
# 4. Restart dev server after changing environment variables
#
# Variable Naming Convention:
# - All Vite env vars must start with VITE_
# - Use SCREAMING_SNAKE_CASE for variable names
# - Group related variables together
#
# Documentation:
# - Vite Env Variables: https://vitejs.dev/guide/env-and-mode.html
# - React + Vite: https://vitejs.dev/guide/env-and-mode.html#env-files
#
# Support:
# - Issues: https://github.com/itsmepraks/BTS-universe/issues
# - Email: hello@praks.me
#
# Made with 💜 for BTS & ARMY
# ============================================================
