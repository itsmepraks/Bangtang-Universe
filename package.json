{
  "name": "bangtan-universe",
  "version": "0.1.0",
  "description": "🌌 Bangtan Universe - An immersive 3D cosmic data visualization exploring BTS's musical universe through interactive glass morphism UI, AI-powered semantic search, and real-time audio analysis. Built with React 19, TypeScript, Vite 7, and Tailwind CSS 4.",
  "private": true,
  "type": "module",
  "keywords": [
    "bts",
    "kpop",
    "music-visualization",
    "data-visualization",
    "3d-visualization",
    "react",
    "typescript",
    "vite",
    "tailwind-css",
    "glass-morphism",
    "cosmic-ui",
    "purple-aesthetic",
    "music-analysis",
    "audio-visualization",
    "semantic-search",
    "rag-search",
    "neural-network",
    "interactive-dashboard",
    "react-19",
    "react-compiler",
    "tailwind-4",
    "vite-7",
    "animation",
    "particles",
    "borahae"
  ],
  "author": {
    "name": "Prakriti Bista",
    "email": "hello@praks.me",
    "url": "https://github.com/itsmepraks"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/itsmepraks/BTS-universe.git"
  },
  "homepage": "https://github.com/itsmepraks/BTS-universe#readme",
  "bugs": {
    "url": "https://github.com/itsmepraks/BTS-universe/issues",
    "email": "hello@praks.me"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/itsmepraks"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:build": "npm run build && npm run preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf node_modules dist .vite",
    "clean:build": "rm -rf dist",
    "analyze": "vite build --mode analyze",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "echo \"Setting up git hooks...\"",
    "db:migrate": "npx tsx scripts/migrate-to-supabase.ts",
    "db:verify": "npx tsx scripts/verify-database.ts",
    "db:update-photos": "npx tsx scripts/update-member-photos.ts",
    "db:upload-photos": "npx tsx scripts/upload-member-photos.ts",
    "scrape:musicbrainz": "npx tsx scripts/scrape-01-musicbrainz-discography.ts",
    "scrape:wiki": "npx tsx scripts/scrape-02-wiki-metadata.ts",
    "scrape:genius": "npx tsx scripts/scrape-03-genius-songs.ts",
    "scrape:albums": "npx tsx scripts/scrape-04-upsert-albums.ts",
    "scrape:songs": "npx tsx scripts/scrape-05-upsert-songs.ts",
    "scrape:lyrics": "npx tsx scripts/scrape-06-genius-lyrics.ts",
    "scrape:verify": "npx tsx scripts/scrape-07-verify-all.ts",
    "scrape:expand-discography": "npx tsx scripts/scrape-08-expand-discography.ts",
    "scrape:cover-art": "npx tsx scripts/scrape-09-cover-art.ts",
    "scrape:lyrics-translations": "npx tsx scripts/scrape-10-lyrics-translations.ts",
    "scrape:awards": "npx tsx scripts/scrape-11-awards.ts",
    "scrape:all": "npm run scrape:musicbrainz && npm run scrape:wiki && npm run scrape:genius && npm run scrape:albums && npm run scrape:songs && npm run scrape:lyrics && npm run scrape:verify"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.93.3",
    "axios": "^1.13.5",
    "cheerio": "^1.2.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.34.3",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.562.0",
    "musicbrainz-api": "^1.1.0",
    "p-limit": "^7.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/cheerio": "^0.22.35",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
