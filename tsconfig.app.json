{
  "compilerOptions": {
    /* Build Configuration */
    // Store incremental build info for faster subsequent builds
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    
    // Target ES2022 for modern JavaScript features
    "target": "ES2022",
    
    // Use standard class fields behavior (ECMAScript proposal)
    "useDefineForClassFields": true,
    
    // Include type definitions for ES2022, DOM APIs, and iterables
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    
    // Use ESNext module system for latest features
    "module": "ESNext",
    
    // Include Vite-specific type definitions (import.meta.env, etc.)
    "types": ["vite/client"],
    
    // Skip type checking of declaration files for faster compilation
    "skipLibCheck": true,

    /* Bundler Mode (Vite-specific) */
    // Use bundler resolution for optimal Vite compatibility
    "moduleResolution": "bundler",
    
    // Allow importing .ts/.tsx files without transpiling
    "allowImportingTsExtensions": true,
    
    // Preserve import/export syntax exactly as written
    "verbatimModuleSyntax": true,
    
    // Force all files to be treated as modules
    "moduleDetection": "force",
    
    // Don't emit JavaScript files (Vite handles compilation)
    "noEmit": true,
    
    // Use React's new JSX transform (no need to import React)
    "jsx": "react-jsx",

    /* Strict Type Checking & Linting */
    // Enable all strict type-checking options
    "strict": true,
    
    // Report errors on unused local variables
    "noUnusedLocals": true,
    
    // Report errors on unused function parameters
    "noUnusedParameters": true,
    
    // Ensure only syntax that can be erased is used (type-only imports)
    "erasableSyntaxOnly": true,
    
    // Report errors for fallthrough cases in switch statements
    "noFallthroughCasesInSwitch": true,
    
    // Ensure imports with side effects are properly marked
    "noUncheckedSideEffectImports": true
  },
  
  // Only compile files in the src directory
  "include": ["src"]
}
